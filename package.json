{
  "name": "quant-research-workbench",
  "private": true,
  "scripts": {
    "dev": "concurrently --names api,web --prefix-colors blue,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm --prefix frontend run dev",
    "dev:api": "python -m uvicorn app.main:app --reload --app-dir backend",
    "build": "npm --prefix frontend run build",
    "test:backend": "python -m unittest tests.test_engine"
  },
  "devDependencies": {
    "concurrently": "9.2.1"
  }
}
